#!/bin/bash
# reset_gmao_db_v2.sh
# -----------------------------------------------------------------------------
# Drops & recreates the GMAO database with the FULL schema (matching prod dump)
# Inserts sample users, machines, tasks, task history & machine data.
# Generates fresh BCrypt password hashes via htpasswd.
# -----------------------------------------------------------------------------

set -e  # exit on first error

# ============================
# CONFIGURATION
# ============================
DB_NAME="gmao_db"
DB_USER="postgres"
DB_PASS="postgres"
DB_HOST="localhost"
DB_PORT="5432"

# Plain passwords (will be hashed with BCrypt)
ADMIN_PWD="Admin@123"
RESP_PWD="Resp@123"
TECH_PWD="Tech@123"

# ============================
# HELPERS
# ============================
run_psql() {
    PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d postgres -c "$1"
}

run_psql_db() {
    PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -c "$1"
}

run_psql_db_file() {
    PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -f "$1"
}

# ============================
# CHECK DEPENDENCIES
# ============================
command -v psql >/dev/null 2>&1 || { echo "[ERROR] psql is not installed."; exit 1; }
command -v htpasswd >/dev/null 2>&1 || { echo "[ERROR] htpasswd is not installed (apt install apache2-utils)."; exit 1; }
command -v uuidgen >/dev/null 2>&1 || { echo "[ERROR] uuidgen is not installed (apt install uuid-runtime)."; exit 1; }

# ============================
# DROP & RECREATE DB
# ============================
echo "[INFO] Disconnecting all sessions from $DB_NAME..."
run_psql "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='$DB_NAME';" >/dev/null

echo "[INFO] Dropping database if exists..."
run_psql "DROP DATABASE IF EXISTS $DB_NAME;" >/dev/null
echo "[OK] Database dropped."

echo "[INFO] Creating database $DB_NAME..."
run_psql "CREATE DATABASE $DB_NAME;" >/dev/null
echo "[OK] Database created."

# ============================
# CREATE TABLES (FULL SCHEMA)
# ============================
echo "[INFO] Creating tables with full schema..."
run_psql_db "
-- =========================
-- USERS
-- =========================
CREATE TABLE users (
    id BIGSERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    email VARCHAR(255) NOT NULL UNIQUE,
    password VARCHAR(255) NOT NULL,
    role VARCHAR(255) NOT NULL,
    address VARCHAR(255),
    city VARCHAR(255),
    postal_code VARCHAR(255),
    id_number VARCHAR(255),
    profile_picture VARCHAR(255),
    uuid VARCHAR(255) UNIQUE,
    two_factor_enabled BOOLEAN NOT NULL DEFAULT FALSE,
    two_factor_secret VARCHAR(255),
    password_reset_token VARCHAR(255),
    password_reset_token_expiry TIMESTAMP(6),
    must_change_password BOOLEAN NOT NULL DEFAULT FALSE,
    created_at TIMESTAMP(6),
    CONSTRAINT users_role_check CHECK (role IN ('ADMIN','RESPONSABLE','TECHNICIAN'))
);

-- =========================
-- MACHINES
-- =========================
CREATE TABLE machines (
    id BIGSERIAL PRIMARY KEY,
    name VARCHAR(255) NOT NULL,
    model VARCHAR(255),
    location VARCHAR(255),
    status VARCHAR(255) NOT NULL,
    maintenance_date DATE,
    created_at TIMESTAMP(6),
    CONSTRAINT machines_status_check CHECK (status IN ('OPERATIONAL','MAINTENANCE','BROKEN','IDLE'))
);

-- =========================
-- TASKS
-- =========================
CREATE TABLE tasks (
    id BIGSERIAL PRIMARY KEY,
    title VARCHAR(255) NOT NULL,
    description TEXT,
    machine_id BIGINT,
    technician_id BIGINT,
    priority VARCHAR(255) NOT NULL,
    status VARCHAR(255) NOT NULL,
    due_date DATE,
    created_at TIMESTAMP(6),
    CONSTRAINT fk_tasks_machine FOREIGN KEY (machine_id) REFERENCES machines(id),
    CONSTRAINT fk_tasks_technician FOREIGN KEY (technician_id) REFERENCES users(id),
    CONSTRAINT tasks_priority_check CHECK (priority IN ('LOW','MEDIUM','HIGH','CRITICAL')),
    CONSTRAINT tasks_status_check CHECK (status IN ('PENDING','IN_PROGRESS','PENDING_APPROVAL','COMPLETED','APPROVED','CANCELLED'))
);

-- =========================
-- TASK HISTORY
-- =========================
CREATE TABLE task_history (
    id BIGSERIAL PRIMARY KEY,
    task_id BIGINT NOT NULL,
    technician_id BIGINT,
    notes TEXT,
    completed_at TIMESTAMP(6),
    CONSTRAINT fk_history_task FOREIGN KEY (task_id) REFERENCES tasks(id),
    CONSTRAINT fk_history_technician FOREIGN KEY (technician_id) REFERENCES users(id)
);

-- =========================
-- MACHINE DATA (telemetry)
-- =========================
CREATE TABLE machine_data (
    id BIGSERIAL PRIMARY KEY,
    machine_id BIGINT NOT NULL,
    temperature DOUBLE PRECISION,
    vibration DOUBLE PRECISION,
    runtime DOUBLE PRECISION,
    created_at TIMESTAMP(6),
    CONSTRAINT fk_data_machine FOREIGN KEY (machine_id) REFERENCES machines(id)
);
" >/dev/null
echo "[OK] Tables created."

# ============================
# GENERATE BCRYPT HASHES
# ============================
echo "[INFO] Generating BCrypt password hashes..."
ADMIN_BCRYPT=$(htpasswd -bnBC 10 "" "$ADMIN_PWD" | tr -d ':\n')
RESP_BCRYPT=$(htpasswd -bnBC 10 "" "$RESP_PWD"  | tr -d ':\n')
TECH_BCRYPT=$(htpasswd -bnBC 10 "" "$TECH_PWD"  | tr -d ':\n')

# Generate UUIDs for each user
ADMIN_UUID=$(uuidgen)
RESP_UUID=$(uuidgen)
TECH1_UUID=$(uuidgen)
TECH2_UUID=$(uuidgen)

# ============================
# INSERT USERS
# ============================
echo "[INFO] Inserting sample users..."
run_psql_db "
INSERT INTO users (name,email,password,role,address,city,postal_code,id_number,uuid,two_factor_enabled,must_change_password,created_at) VALUES
('Admin GMAO','admin@gmao.com','$ADMIN_BCRYPT','ADMIN','123 Industrial Zone','Tunis','1000','ADM001','$ADMIN_UUID',FALSE,FALSE,NOW()),
('Mohamed Ali','responsable@gmao.com','$RESP_BCRYPT','RESPONSABLE','456 Factory St','Sfax','3000','RSP001','$RESP_UUID',FALSE,FALSE,NOW()),
('Karim Sassi','tech1@gmao.com','$TECH_BCRYPT','TECHNICIAN','789 Workshop Ave','Sousse','4000','TCH001','$TECH1_UUID',FALSE,FALSE,NOW()),
('Amira Ben Salah','tech2@gmao.com','$TECH_BCRYPT','TECHNICIAN','321 Maintenance Rd','Monastir','5000','TCH002','$TECH2_UUID',FALSE,FALSE,NOW());
" >/dev/null

# Capture user IDs
RESP_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM users WHERE email='responsable@gmao.com';")
TECH1_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM users WHERE email='tech1@gmao.com';")
TECH2_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM users WHERE email='tech2@gmao.com';")
echo "[OK] Users inserted."

# ============================
# INSERT MACHINES
# ============================
echo "[INFO] Inserting sample machines..."
run_psql_db "
INSERT INTO machines (name,model,location,status,maintenance_date,created_at) VALUES
('CNC Machine Alpha','FANUC-30i','Workshop A','BROKEN','2026-05-23',NOW()),
('Lathe Machine Beta','DMG-CLX500','Workshop B','BROKEN','2026-04-23',NOW()),
('Hydraulic Press Gamma','ENERPAC-P142','Press Room','IDLE','2026-03-18',NOW()),
('Air Compressor Delta','ATLAS-GA55','Utility Room','OPERATIONAL','2026-06-23',NOW()),
('Conveyor Belt Epsilon','INTRALOX-T500','Assembly Line','OPERATIONAL','2026-03-23',NOW());
" >/dev/null

M1_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM machines WHERE name='CNC Machine Alpha';")
M2_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM machines WHERE name='Lathe Machine Beta';")
M3_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM machines WHERE name='Hydraulic Press Gamma';")
M4_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM machines WHERE name='Air Compressor Delta';")
M5_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM machines WHERE name='Conveyor Belt Epsilon';")
echo "[OK] Machines inserted."

# ============================
# INSERT TASKS
# ============================
echo "[INFO] Inserting sample tasks..."
run_psql_db "
INSERT INTO tasks (title,description,machine_id,technician_id,priority,status,due_date,created_at) VALUES
('CNC Temperature Inspection','Inspect and clean cooling system on CNC Machine Alpha. Temperature trending above warning threshold.',$M1_ID,$TECH1_ID,'HIGH','APPROVED','2026-03-25',NOW()),
('Hydraulic Press Emergency Maintenance','Critical vibration detected. Inspect bearings, mounting, and hydraulic seals.',$M3_ID,$TECH2_ID,'CRITICAL','PENDING','2026-03-23',NOW()),
('Conveyor Belt Repair','Conveyor belt has stopped. Diagnose fault and replace damaged components.',$M5_ID,$TECH1_ID,'CRITICAL','IN_PROGRESS','2026-03-23',NOW()),
('Lathe Monthly Lubrication','Perform monthly lubrication routine on DMG CLX500 lathe machine.',$M2_ID,$TECH2_ID,'LOW','COMPLETED','2026-03-20',NOW()),
('Compressor Filter Replacement','Replace air filters on Atlas GA55 compressor. Runtime approaching maintenance threshold.',$M4_ID,$TECH1_ID,'MEDIUM','PENDING','2026-03-30',NOW());
" >/dev/null

T1_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM tasks WHERE title='CNC Temperature Inspection';")
T4_ID=$(PGPASSWORD=$DB_PASS psql -U $DB_USER -h $DB_HOST -p $DB_PORT -d $DB_NAME -t -A -c "SELECT id FROM tasks WHERE title='Lathe Monthly Lubrication';")
echo "[OK] Tasks inserted."

# ============================
# INSERT TASK HISTORY
# ============================
echo "[INFO] Inserting task history..."
run_psql_db "
INSERT INTO task_history (task_id,technician_id,notes,completed_at) VALUES
($T1_ID,$TECH1_ID,'Task submitted for approval',NOW() - INTERVAL '2 days'),
($T1_ID,$RESP_ID,'Task approved by responsable',NOW() - INTERVAL '1 day'),
($T4_ID,$TECH2_ID,'Lubrication routine completed successfully',NOW() - INTERVAL '5 days');
" >/dev/null
echo "[OK] Task history inserted."

# ============================
# INSERT MACHINE DATA (TELEMETRY)
# ============================
echo "[INFO] Inserting machine telemetry..."
run_psql_db "
INSERT INTO machine_data (machine_id,temperature,vibration,runtime,created_at) VALUES
($M1_ID,87.5,3.2,950,NOW()),
($M1_ID,85.0,3.0,948,NOW()),
($M2_ID,55.0,2.1,320,NOW()),
($M2_ID,53.0,2.0,318,NOW()),
($M3_ID,65.0,8.9,1100,NOW()),
($M3_ID,68.0,9.1,1098,NOW()),
($M4_ID,72.0,4.8,820,NOW()),
($M5_ID,95.0,7.5,1350,NOW());
" >/dev/null
echo "[OK] Machine data inserted."

# ============================
# SUMMARY
# ============================
echo ""
echo "================================================================"
echo "[DONE] GMAO database fully reset and ready."
echo "----------------------------------------------------------------"
echo "  Connection:  postgresql://$DB_USER@$DB_HOST:$DB_PORT/$DB_NAME"
echo ""
echo "  Test accounts (passwords stored as BCrypt):"
echo "    admin@gmao.com         / $ADMIN_PWD   (ADMIN)"
echo "    responsable@gmao.com   / $RESP_PWD    (RESPONSABLE)"
echo "    tech1@gmao.com         / $TECH_PWD    (TECHNICIAN)"
echo "    tech2@gmao.com         / $TECH_PWD    (TECHNICIAN)"
echo "================================================================"
    "<div class='row'><span class='label'>Commit</span><span class='value'>" + COMMIT + "</span></div>"
    "<div class='row'><span class='label'>Declenche par</span><span class='value'>" + ACTOR + "</span></div>"
    "<div class='row'><span class='label'>Date</span><span class='value'>" + DATE + "</span></div></div>"
    "<div class='card' style='border-left:4px solid " + fc + "'><h2>Statut de chaque job</h2>"
    "<div class='row'><span class='label'>JOB 0 - Validation code</span>" + job_badge(J0) + "</div>"
    "<div class='row'><span class='label'>JOB 1 - Creation VM EC2</span>" + job_badge(J1) + "</div>"
    "<div class='row'><span class='label'>JOB 2 - Post-installation</span>" + job_badge(J2) + "</div>"
    "<div class='row'><span class='label'>JOB 3 - Demarrage application</span>" + job_badge(J3) + "</div>"
    "<div class='row'><span class='label'>JOB 4 - SAST</span><span class='value' style='font-size:11px'>" + J4_SAST + " - " + J4_SUMMARY + "</span></div>"
    "<div class='row'><span class='label'>JOB 5 - DAST</span><span class='value' style='font-size:11px'>" + J5_DAST + " - " + J5_SUMMARY + "</span></div>"
    "<div class='row'><span class='label'>JOB 6 - Monitoring</span><span class='value' style='font-size:11px'>CPU: " + CPU + "% | MEM: " + MEM + "% | DISK: " + DISK + "%</span></div></div>"
    "<div class='card' style='border-left:4px solid " + fc + "'><h2>Acces a l application</h2>"
    "<div class='url-box'>Backend  : http://" + VM_IP + ":8080</div>"
    "<div class='url-box'>Frontend : http://" + VM_IP + ":4200</div></div>"
    "<a href='" + RUN_URL + "' class='btn'>Voir dans GitHub Actions</a>"
    "</div><div class='footer'>GMAO Pipeline CI/CD - resume automatique - " + DATE + "</div></div></body></html>")
send_email(TO, "[GMAO] " + fs + " - " + DATE, html4)

print("Tous les emails ont ete envoyes avec succes.")
PYEOF

      - name: Envoi des 4 emails de rapport
        env:
          RUN_URL:     ${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}
          BRANCH:      ${{ github.ref_name }}
          COMMIT:      ${{ github.sha }}
          ACTOR:       ${{ github.actor }}
          VM_IP:       ${{ env.VM_IP }}
          INSTANCE_ID: ${{ env.INSTANCE_ID }}
          J0_STATUS:   ${{ env.J0_STATUS }}
          J1_STATUS:   ${{ env.J1_STATUS }}
          J2_STATUS:   ${{ env.J2_STATUS }}
          J3_STATUS:   ${{ env.J3_STATUS }}
          J4_SAST:     ${{ env.J4_SAST }}
          J4_SUMMARY:  ${{ env.J4_SUMMARY }}
          J4_BLOCKING: ${{ env.J4_BLOCKING }}
          J5_DAST:     ${{ env.J5_DAST }}
          J5_SUMMARY:  ${{ env.J5_SUMMARY }}
          CPU:         ${{ env.CPU }}
          MEM:         ${{ env.MEM }}
          DISK:        ${{ env.DISK }}
          MEM_TOTAL:   ${{ env.MEM_TOTAL }}
          MEM_USED:    ${{ env.MEM_USED }}
          DISK_TOTAL:  ${{ env.DISK_TOTAL }}
          DISK_USED:   ${{ env.DISK_USED }}
          DISK_FREE:   ${{ env.DISK_FREE }}
          UPTIME:      ${{ env.UPTIME }}
          LOAD:        ${{ env.LOAD }}
          BACKEND_S:   ${{ env.BACKEND_S }}
          FRONTEND_S:  ${{ env.FRONTEND_S }}
          ALARM_CPU:   ${{ env.ALARM_CPU }}
          ALARM_MEM:   ${{ env.ALARM_MEM }}
          ALARM_DISK:  ${{ env.ALARM_DISK }}
          GMAIL_USER:  ${{ secrets.GMAIL_USER }}
        run: |
          export DATE=$(date '+%d/%m/%Y %H:%M:%S')
          python3 /tmp/send_emails.py

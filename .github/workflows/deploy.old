name: GMAO — Deploy Pipeline

on:
  push:
    branches: [master]
  workflow_dispatch:   # Déclenchement manuel depuis GitHub UI

env:
  TF_DIR: ./terraform
  AWS_REGION: us-east-1

jobs:

# ════════════════════════════════════════════════════════════════════════════
#  JOB 1 — Création de la VM EC2 (Ubuntu 20.04 / t2.large / vockey)
# ════════════════════════════════════════════════════════════════════════════
  job1_create_vm:
    name: "JOB 1 — Création VM EC2"
    runs-on: ubuntu-latest

    outputs:
      public_ip:   ${{ steps.tf_out.outputs.public_ip }}
      instance_id: ${{ steps.tf_out.outputs.instance_id }}

    steps:
      - name: 📥 Checkout du dépôt
        uses: actions/checkout@v4

      # ── Credentials AWS (depuis GitHub Secrets) ──────────────────────────
      - name: 🔑 Configuration credentials AWS
        uses: aws-actions/configure-aws-credentials@v4
        with:
          aws-access-key-id:     ${{ secrets.AWS_ACCESS_KEY_ID }}
          aws-secret-access-key: ${{ secrets.AWS_SECRET_ACCESS_KEY }}
          aws-session-token:     ${{ secrets.AWS_SESSION_TOKEN }}
          aws-region:            ${{ env.AWS_REGION }}

      # ── Terraform ────────────────────────────────────────────────────────
      - name: 🏗️ Setup Terraform
        uses: hashicorp/setup-terraform@v3
        with:
          terraform_version: "1.6.0"
          terraform_wrapper: false

      - name: 🔧 Terraform Init
        working-directory: ${{ env.TF_DIR }}
        run: terraform init

      - name: ✅ Terraform Validate
        working-directory: ${{ env.TF_DIR }}
        run: terraform validate

      - name: 📋 Terraform Plan
        working-directory: ${{ env.TF_DIR }}
        run: terraform plan -out=tfplan

      - name: 🚀 Terraform Apply
        working-directory: ${{ env.TF_DIR }}
        run: terraform apply -auto-approve tfplan

      # ── Récupération de l'IP pour les jobs suivants ───────────────────────
      - name: 📤 Export des outputs Terraform
        id: tf_out
        working-directory: ${{ env.TF_DIR }}
        run: |
          PUBLIC_IP=$(terraform output -raw public_ip)
          INSTANCE_ID=$(terraform output -raw instance_id)
          echo "public_ip=$PUBLIC_IP"   >> $GITHUB_OUTPUT
          echo "instance_id=$INSTANCE_ID" >> $GITHUB_OUTPUT
          echo "✅ VM créée → ID: $INSTANCE_ID | IP: $PUBLIC_IP"

      # ── Attente que le SSH soit disponible (la VM démarre en ~30-60s) ─────
      - name: ⏳ Attente SSH disponible (2 min max)
        run: |
          VM_IP="${{ steps.tf_out.outputs.public_ip }}"
          echo "Attente du port 22 sur $VM_IP..."
          for i in $(seq 1 24); do
            if nc -zv "$VM_IP" 22 2>/dev/null; then
              echo "✅ SSH disponible !"
              exit 0
            fi
            echo "  Tentative $i/24 — 5s..."
            sleep 5
          done
          echo "❌ SSH non disponible après 2 minutes"
          exit 1

# ════════════════════════════════════════════════════════════════════════════
#  JOB 2 — Post-installation (packages + projets)
# ════════════════════════════════════════════════════════════════════════════
  job2_post_install:
    name: "JOB 2 — Post-Installation"
    runs-on: ubuntu-latest
    needs: job1_create_vm

    env:
      VM_IP: ${{ needs.job1_create_vm.outputs.public_ip }}

    steps:
      - name: 📥 Checkout du dépôt
        uses: actions/checkout@v4

      # ── Préparation de la clé SSH vockey ─────────────────────────────────
      - name: 🔑 Configuration clé SSH (vockey)
        run: |
          mkdir -p ~/.ssh
          echo "${{ secrets.SSH_PRIVATE_KEY }}" > ~/.ssh/vockey.pem
          chmod 600 ~/.ssh/vockey.pem
          # Désactiver strict host checking pour éviter les prompts interactifs
          cat >> ~/.ssh/config <<EOF
          Host ${{ env.VM_IP }}
            StrictHostKeyChecking no
            UserKnownHostsFile /dev/null
            IdentityFile ~/.ssh/vockey.pem
          EOF

      # ── Copie et exécution du script ──────────────────────────────────────
      - name: 📤 Copie du script post-install sur la VM
        run: |
          scp -i ~/.ssh/vockey.pem \
              -o StrictHostKeyChecking=no \
              scripts/02_post_install.sh \
              ubuntu@${{ env.VM_IP }}:~/02_post_install.sh

      - name: ⚙️ Exécution du post-install (Java, Maven, PostgreSQL, Node, npm, projets)
        timeout-minutes: 15
        run: |
          ssh -i ~/.ssh/vockey.pem \
              -o StrictHostKeyChecking=no \
              ubuntu@${{ env.VM_IP }} \
              "chmod +x ~/02_post_install.sh && ~/02_post_install.sh"

      # ── Vérification rapide ───────────────────────────────────────────────
      - name: ✅ Vérification des installations
        run: |
          ssh -i ~/.ssh/vockey.pem \
              -o StrictHostKeyChecking=no \
              ubuntu@${{ env.VM_IP }} \
              "echo '=== Outils ===' && \
               java -version 2>&1 | head -1 && \
               mvn -version 2>&1 | head -1 && \
               psql --version && \
               node -v && npm -v && \
               echo '=== Projets ===' && \
               ls ~/gmao-backend/ && echo '✅ gmao-backend OK' && \
               ls ~/gmao-frontend/ && echo '✅ gmao-frontend OK'"

# ════════════════════════════════════════════════════════════════════════════
#  JOB 3 — Lancement de l'application (DB restore + Backend + Frontend)
# ════════════════════════════════════════════════════════════════════════════
  job3_start_app:
    name: "JOB 3 — Démarrage Application GMAO"
    runs-on: ubuntu-latest
    needs: [job1_create_vm, job2_post_install]

    env:
      VM_IP: ${{ needs.job1_create_vm.outputs.public_ip }}

    steps:
      - name: 📥 Checkout du dépôt
        uses: actions/checkout@v4

      - name: 🔑 Configuration clé SSH (vockey)
        run: |
          mkdir -p ~/.ssh
          echo "${{ secrets.SSH_PRIVATE_KEY }}" > ~/.ssh/vockey.pem
          chmod 600 ~/.ssh/vockey.pem

      - name: 📤 Copie du script de démarrage
        run: |
          scp -i ~/.ssh/vockey.pem \
              -o StrictHostKeyChecking=no \
              scripts/03_start_app.sh \
              ubuntu@${{ env.VM_IP }}:~/03_start_app.sh

      - name: 🚀 Lancement (restore DB + Spring Boot + React)
        timeout-minutes: 10
        run: |
          ssh -i ~/.ssh/vockey.pem \
              -o StrictHostKeyChecking=no \
              ubuntu@${{ env.VM_IP }} \
              "chmod +x ~/03_start_app.sh && ~/03_start_app.sh"

      # ── Test de connectivité final ────────────────────────────────────────
      - name: 🔍 Test de connectivité Backend (port 8080)
        run: |
          echo "Test http://${{ env.VM_IP }}:8080 ..."
          for i in $(seq 1 12); do
            if curl -s --max-time 5 http://${{ env.VM_IP }}:8080 > /dev/null 2>&1; then
              echo "✅ Backend répond sur le port 8080"
              break
            fi
            echo "  Tentative $i/12..."
            sleep 5
          done

      - name: 🔍 Test de connectivité Frontend (port 3000)
        run: |
          echo "Test http://${{ env.VM_IP }}:3000 ..."
          for i in $(seq 1 12); do
            if curl -s --max-time 5 http://${{ env.VM_IP }}:3000 > /dev/null 2>&1; then
              echo "✅ Frontend répond sur le port 3000"
              break
            fi
            echo "  Tentative $i/12..."
            sleep 5
          done

      # ── Résumé final ──────────────────────────────────────────────────────
      - name: 📋 Résumé du déploiement
        run: |
          echo ""
          echo "╔════════════════════════════════════════════════╗"
          echo "║       DÉPLOIEMENT GMAO TERMINÉ ✅              ║"
          echo "╠════════════════════════════════════════════════╣"
          echo "║  Backend  → http://${{ env.VM_IP }}:8080  ║"
          echo "║  Frontend → http://${{ env.VM_IP }}:3000  ║"
          echo "╚════════════════════════════════════════════════╝"
